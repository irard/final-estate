add_action('wp_ajax_get_properties_dashboard', 'ef_handle_get_properties_dashboard'); 
if (!function_exists('ef_handle_get_properties_dashboard')) { 
function ef_handle_get_properties_dashboard() { 
    check_ajax_referer('ef_property_nonce', 'nonce'); 
    if (!is_user_logged_in()) { 
        wp_send_json_error('Unauthorized.'); 
    } 
 
    $properties = get_posts([ 
        'post_type'   => 'property', 
        'numberposts' => -1, 
        'post_status' => 'publish', 
        'orderby'     => 'date', 
        'order'       => 'DESC' 
    ]); 
 
    if (empty($properties)) { 
        wp_send_json_success([]); 
    } 
 
    $property_ids = wp_list_pluck($properties, 'ID'); 
 
 
    $all_tenants = get_posts([ 
        'post_type'   => 'ef_tenant', 
        'post_status' => 'publish', 
        'numberposts' => -1
    ]); 
 
    $tenants_by_property = []; 
    $all_tenant_ids = []; 
    foreach ($all_tenants as $t) { 
        $p_id = ef_get_tenant_property_id($t->ID);
        if ($p_id && in_array($p_id, $property_ids)) {
            $tenants_by_property[$p_id][] = $t; 
        }
        $all_tenant_ids[] = $t->ID; 
    } 
 
 
    $period_data = ef_get_dashboard_period();
    $current_month = $period_data['m']; 
    $current_year  = $period_data['y']; 
    $current_period = $period_data['period'];
 
    $all_payments = get_posts([ 
        'post_type'      => 'payment', 
        'numberposts'    => -1, 
        'post_status'    => ['publish', 'future', 'pending', 'draft', 'private']
    ]); 
 
    $payments_by_tenant = []; 
    $payments_by_property = [];
    foreach ($all_payments as $pay) { 
        if (strpos(ef_get_payment_period($pay->ID), $current_period) === 0) {
            $t_id = ef_get_payment_tenant_id($pay->ID);
            if ($t_id) {
                $payments_by_tenant[$t_id][] = $pay; 
            }
            $p_id = ef_get_payment_property_id($pay->ID);
            if ($p_id) {
                $payments_by_property[$p_id][] = $pay;
            }
        }
    } 
 
    $data = []; 
    foreach ($properties as $p) { 
        $p_tenants = isset($tenants_by_property[$p->ID]) ? $tenants_by_property[$p->ID] : []; 
        $occupied = count($p_tenants); 
 
        $units = 0; 
        if (function_exists('get_field')) { 
            $units = intval(get_field('number_unit', $p->ID)); 
        } 
        if (!$units) { 
            $units = intval(get_post_meta($p->ID, 'number_unit', true)) ?: intval(get_post_meta($p->ID, 'property_units', true)) ?: 0; 
        } 
 
        $expected = 0; 
        $collected = 0; 
        $billable_count = 0;
        $progress_sum = 0;

        $p_pay_total = 0;
        $p_payments = isset($payments_by_property[$p->ID]) ? $payments_by_property[$p->ID] : [];
        foreach ($p_payments as $pay) {
            $p_pay_total += ef_clean_amount(get_field('amount_paid', $pay->ID) ?: get_post_meta($pay->ID, 'amount_paid', true));
        }
        $collected = $p_pay_total;

        foreach ($p_tenants as $t) { 
            if (function_exists("ef_is_tenant_billable") && !ef_is_tenant_billable($t->ID, $current_month, $current_year)) continue; 
            
            $billable_count++;
            $rent_val = get_field('monthly_rent', $t->ID) ?: get_post_meta($t->ID, 'monthly_rent', true); 
            $monthly_rent = ef_clean_amount($rent_val);
            $expected += $monthly_rent; 
 
            $t_paid_total = 0;
            $t_payments = isset($payments_by_tenant[$t->ID]) ? $payments_by_tenant[$t->ID] : []; 
            foreach ($t_payments as $pay) { 
                $amount_val = get_field('amount_paid', $pay->ID) ?: get_post_meta($pay->ID, 'amount_paid', true); 
                $t_paid_total += ef_clean_amount($amount_val);
            } 

            if ($monthly_rent > 0) {
                $progress_sum += min(1, $t_paid_total / $monthly_rent);
            } elseif ($t_paid_total > 0) {
                $progress_sum += 1;
            }
        } 
 
        $col_pct = ($billable_count > 0) ? round(($progress_sum / $billable_count) * 100) : 0;

        $data[] = [ 
            'id'        => $p->ID, 
            'name'      => function_exists('get_field') ? (get_field('add_property', $p->ID) ?: $p->post_title) : $p->post_title, 
            'type'      => function_exists('get_field') ? (get_field('property_type', $p->ID) ?: 'Property') : (get_post_meta($p->ID, 'property_type', true) ?: 'Property'), 
            'units'     => $units, 
            'occupied'  => $occupied, 
            'address'   => function_exists('get_field') ? get_field('add_address', $p->ID) : get_post_meta($p->ID, 'add_address', true), 
            'expected'  => $expected, 
            'collected' => $collected,
            'col_pct'   => $col_pct
        ]; 
    } 
    wp_send_json_success($data); 
} 
} 
 
