if (!function_exists('ef_get_payment_period')) {
    function ef_get_payment_period($p_id) {
        $p = get_field('payment_period', $p_id) ?: get_post_meta($p_id, 'payment_period', true);
        if ($p) return substr((string)$p, 0, 7);
        $d = get_field('date_of_payment', $p_id) ?: get_post_meta($p_id, 'date_of_payment', true);
        if ($d) {
            $d = (string)$d;
            if (strpos($d, '/') !== false) {
                $parts = explode('/', $d);
                if (count($parts) === 3) {
                    if (strlen($parts[2]) === 4) return "$parts[2]-" . str_pad($parts[1], 2, '0', STR_PAD_LEFT);
                    if (strlen($parts[0]) === 4) return "$parts[0]-" . str_pad($parts[1], 2, '0', STR_PAD_LEFT);
                }
            }
            $ts = strtotime($d);
            if ($ts) return date('Y-m', $ts);
        }
        return get_the_date('Y-m', $p_id);
    }
}

if (!function_exists('ef_get_tenant_monthly_status')) {
    function ef_get_tenant_monthly_status($t_id, $m, $y) {
        $rent_val = get_field('monthly_rent', $t_id) ?: get_post_meta($t_id, 'monthly_rent', true);
        $rent = ef_clean_amount($rent_val);
        $period_match = "$y-$m";
        
        $payments = get_posts([
            'post_type' => 'payment',
            'post_status' => ['publish', 'future', 'pending', 'draft', 'private'],
            'numberposts' => -1
        ]);

        $paid = 0;
        foreach ($payments as $p) {
            $p_id = $p->ID;
            if (ef_get_payment_tenant_id($p_id) == intval($t_id)) {
                $p_period = ef_get_payment_period($p_id);
                if (strpos($p_period, $period_match) === 0) {
                    $amt_val = get_field('amount_paid', $p_id) ?: get_post_meta($p_id, 'amount_paid', true);
                    $paid += ef_clean_amount($amt_val);
                }
            }
        }

        return [
            'paid' => $paid,
            'rent' => $rent,
            'is_fully_paid' => ($rent > 0 && $paid >= $rent) || ($rent == 0 && $paid > 0)
        ];
    }
}
add_action('wp_ajax_save_property', 'ef_handle_save_property'); 
 
if (!function_exists('ef_handle_save_property')) { 
function ef_handle_save_property() { 
    check_ajax_referer('ef_property_nonce', 'nonce'); 
    if (!is_user_logged_in()) { 
        wp_send_json_error('Unauthorized.'); 
    } 
 
    $property_id = !empty($_POST['property_id']) ? intval($_POST['property_id']) : 0; 
 
    if (empty($_POST['name']) || empty($_POST['type']) || !isset($_POST['units']) || $_POST['units'] === '' || empty($_POST['address'])) { 
        wp_send_json_error('All fields are required.'); 
    } 
 
    $name    = sanitize_text_field($_POST['name']);
    $address = sanitize_text_field($_POST['address']); 
 
    $duplicate_check = get_posts([ 
        'post_type'  => 'property', 
        'meta_query' => [ 
            'relation' => 'AND',
            [ 
                'key'   => 'add_address', 
                'value' => $address, 
            ],
            [
                'key'   => 'add_property',
                'value' => $name,
            ]
        ], 
        'exclude'    => [$property_id], 
        'fields'     => 'ids', 
        'numberposts'=> 1 
    ]); 
 
    if (!empty($duplicate_check)) { 
        wp_send_json_error('A property with this name and address already exists.'); 
    } 
 
    $post_data = [ 
        'post_title'  => $name, 
        'post_type'   => 'property', 
        'post_status' => 'publish' 
    ]; 
 
    if ($property_id > 0) { 
        if (get_post_type($property_id) !== 'property') { 
            wp_send_json_error('Invalid property ID provided.'); 
        } 
        $post_data['ID'] = $property_id; 
        $post_id = wp_update_post($post_data); 
    } else { 
        $post_id = wp_insert_post($post_data); 
    } 
 
    if (is_wp_error($post_id) || $post_id === 0) { 
        $err_msg = is_wp_error($post_id) ? $post_id->get_error_message() : 'Failed to save post.'; 
        wp_send_json_error('Database Error: ' . $err_msg); 
    } 
 
    $type    = sanitize_text_field($_POST['type']); 
    $units   = intval($_POST['units']); 
 
    if (function_exists('update_field')) { 
        update_field('add_property', $name, $post_id); 
        update_field('property_type', $type, $post_id); 
        update_field('number_unit', $units, $post_id); 
        update_field('add_address', $address, $post_id); 
    } else { 
        update_post_meta($post_id, 'add_property', $name); 
        update_post_meta($post_id, 'property_type', $type); 
        update_post_meta($post_id, 'number_unit', $units); 
        update_post_meta($post_id, 'add_address', $address); 
    } 
 
 
    update_post_meta($post_id, 'property_units', $units); 
 
    wp_send_json_success(['id' => $post_id]); 
} 
} 
 
