if (!function_exists('ef_get_tenant_next_due_date')) {  
    function ef_get_tenant_next_due_date($t_id, $relative_to = null) {  
        $due_day = ef_get_tenant_due_day($t_id);  
          
        $now_str = $relative_to ?: (function_exists('current_time') ? current_time('mysql') : 'now');  
        $today = new DateTimeImmutable($now_str);  
         
        // Find the due date for the current month 
        $days_in_month = (int)$today->format('t'); 
        $this_month_due = $today->setDate((int)$today->format('Y'), (int)$today->format('m'), min($due_day, $days_in_month))->setTime(0, 0, 0); 
         
        // If already paid for this month, the next due is next month 
        $status = ef_get_tenant_monthly_status($t_id, $this_month_due->format('m'), $this_month_due->format('Y')); 
        if ($status['is_fully_paid']) { 
            $date = $today->modify('first day of next month'); 
            $days_in_next_month = (int)$date->format('t'); 
            return $date->setDate((int)$date->format('Y'), (int)$date->format('m'), min($due_day, $days_in_next_month))->setTime(0, 0, 0); 
        } 
 
        return $this_month_due; 
    }  
}  
  
  
if (!function_exists('ef_get_tenant_monthly_status')) {    
    function ef_get_tenant_monthly_status($t_id, $month, $year) {    
        $monthly_rent = floatval(get_field('monthly_rent', $t_id) ?: get_post_meta($t_id, 'monthly_rent', true));    
    
        $period_match = $year . '-' . str_pad($month, 2, '0', STR_PAD_LEFT);
        $payments = get_posts(array(    
            'post_type'      => 'payment',    
            'post_status'    => ['publish', 'future'],
            'posts_per_page' => -1,    
            'meta_query'     => array(
                array('key' => 'associated_tenant', 'value' => $t_id, 'compare' => '=' )
            )
        ));    
    
        $tenant_paid_this_month = 0.00;    
        foreach ($payments as $p) {    
            $p_id = $p->ID;
            $period = get_field('payment_period', $p_id) ?: get_post_meta($p_id, 'payment_period', true) ?: get_the_date('Y-m', $p_id);
            if (strpos($period, $period_match) === 0) {
                $amount = get_field('amount_paid', $p_id) ?: get_post_meta($p_id, 'amount_paid', true);    
                if ($amount) {    
                    $tenant_paid_this_month += floatval($amount);    
                }    
            }
        }    
    
        return array(    
            'paid' => $tenant_paid_this_month,    
            'rent' => $monthly_rent,    
            'balance' => max(0, $monthly_rent - $tenant_paid_this_month),    
            'is_fully_paid' => ($tenant_paid_this_month >= $monthly_rent && $monthly_rent > 0)    
        );    
    }    
}    
 
 
