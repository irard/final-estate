    $revenue_dataset = array(); 
    $month_labels = array('Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'); 
     
    for ($m = 1; $m <= 12; $m++) { 
        $padded_month = str_pad($m, 2, '0', STR_PAD_LEFT); 
        $period_match = $selected_year . '-' . $padded_month;
        $p_query = new WP_Query(array( 
            'post_type'      => 'payment', 
            'post_status'    => ['publish', 'future'],
            'posts_per_page' => -1, 
        )); 
         
        $revenue_collected = 0.00; 
        if ($p_query->have_posts()) { 
            while ($p_query->have_posts()) { 
                $p_query->the_post(); 
                $p_id = get_the_ID();
                $period = get_field('payment_period', $p_id) ?: get_post_meta($p_id, 'payment_period', true) ?: get_the_date('Y-m', $p_id);
                if (strpos($period, $period_match) === 0) {
                    $pay_val = get_field('amount_paid', $p_id) ?: get_post_meta($p_id, 'amount_paid', true); 
                    if ($pay_val) { $revenue_collected += floatval($pay_val); } 
                }
            } 
            wp_reset_postdata(); 
        } 
        $revenue_dataset[] = $revenue_collected; 
    } 
 
    $current_month_index = intval(date('n', $current_time)) - 1; // 0-11 
 
    ob_start(); 
    ?> 
