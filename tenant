    $t_query = new WP_Query(array('post_type' => 'ef_tenant', 'post_status' => 'publish', 'posts_per_page' => -1));
    $tenants = [];
    if ($t_query->have_posts()) {
        while ($t_query->have_posts()) {
            $t_query->the_post();
            $t_id = get_the_ID();
            $tenants[] = [
                'id'   => $t_id,
                'rent' => floatval(get_field('monthly_rent', $t_id) ?: get_post_meta($t_id, 'monthly_rent', true))
            ];
        }
        wp_reset_postdata();
    }

    $months = array('Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec');
    $report_rows = array();
    $total_yearly_revenue = 0; $total_yearly_expected = 0; $total_yearly_gap = 0;

    foreach ($months as $index => $month_name) {
        $padded_month = str_pad($index + 1, 2, '0', STR_PAD_LEFT);
        $period_match = $year . '-' . $padded_month;

        $p_query = new WP_Query(array(
            'post_type'      => 'payment',
            'post_status'    => ['publish', 'future'],
            'posts_per_page' => -1,
        ));

        $collected_monthly = 0.00;
