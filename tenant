add_shortcode('outstanding_tenants', function() {   
    if ( ! function_exists( 'get_field' ) ) { 
        return ''; 
    } 
 
    $current_month_year = date('Y-m');   
       
    $tenants = get_posts([   
        'post_type'      => 'ef_tenant',   
        'post_status'    => 'publish',   
        'posts_per_page' => -1,   
    ]);   
   
    $payments_by_tenant = [];   
    $outstanding_items = []; 
 
    if (!empty($tenants)) { 
        $current_period = date('Y-m');
        $p_query = new WP_Query([   
            'post_type'      => 'payment',   
            'post_status'    => ['publish', 'future'],
            'posts_per_page' => -1,   
        ]);   
   
        if ($p_query->have_posts()) {   
            while ($p_query->have_posts()) {   
                $p_query->the_post();   
                $pay_id = get_the_ID();   
                $period = get_field('payment_period', $pay_id) ?: get_post_meta($pay_id, 'payment_period', true) ?: get_the_date('Y-m', $pay_id);
                if (strpos($period, $current_period) === 0) {
                    $tid = get_field('associated_tenant', $pay_id) ?: get_post_meta($pay_id, 'associated_tenant', true);   
                    $amount = floatval(get_field('amount_paid', $pay_id) ?: get_post_meta($pay_id, 'amount_paid', true));   
                       
                    if ($tid) {   
                        if (!isset($payments_by_tenant[$tid])) {   
                            $payments_by_tenant[$tid] = 0;   
                        }   
                        $payments_by_tenant[$tid] += $amount;   
                    }
                }   
            }   
            wp_reset_postdata();   
        }   
   
        $m = date('m'); $y = date('Y');
        foreach ($tenants as $tenant) {   
            $tid = $tenant->ID;   
            if (ef_is_tenant_billable($tid, $m, $y)) {
                $rent = floatval(get_field('monthly_rent', $tid) ?: get_post_meta($tid, 'monthly_rent', true));   
                   
                if ($rent <= 0) continue;   
    
                $paid = isset($payments_by_tenant[$tid]) ? $payments_by_tenant[$tid] : 0; 
   
                if ($paid < $rent) {   
                    $due_day = get_field('rent_due_day', $tid) ?: get_post_meta($tid, 'rent_due_day', true);   
                    $outstanding_items[] = [   
                        'name'    => get_the_title($tid),   
                        'due_day' => $due_day ?: '01',   
                        'amount'  => $rent - $paid   
                    ];   
                }
            }   
        }   
   
        usort($outstanding_items, function($a, $b) {   
            return intval($a['due_day']) <=> intval($b['due_day']);   
        });   
    } 

    $items_html = '';
    $count = count($outstanding_items);

    foreach ($outstanding_items as $item) {
        $items_html .= "
        <div class='ef-reminder-item'>
            <div>
                <div class='ef-reminder-item-name'>" . esc_html($item['name']) . "</div>
                <div class='ef-reminder-item-sub'>Due day " . esc_html($item['due_day']) . "</div>
            </div>
            <div style='text-align: right;'>
