add_shortcode('ef_upcoming_due_this_week', function() {
    $start_of_week = strtotime('monday this week 00:00:00');
    $end_of_week   = strtotime('sunday this week 23:59:59');

    $t_query = new WP_Query(array(
        'post_type'      => 'ef_tenant',
        'post_status'    => 'publish',
        'posts_per_page' => -1,
    ));

    $upcoming_dues = array();
    $current_year  = date('Y');
    $current_month = date('m');

    if ($t_query->have_posts()) {
        while ($t_query->have_posts()) {
            $t_query->the_post();
            $t_id = $t_query->post->ID;

            $due_day = get_field('rent_due_day', $t_id);

            if ($due_day) {
                $due_timestamp = strtotime("$current_year-$current_month-" . str_pad($due_day, 2, '0', STR_PAD_LEFT));

                if ($due_timestamp >= $start_of_week && $due_timestamp <= $end_of_week) {
                    $upcoming_dues[] = array(
                        'name' => get_the_title(),
                        'date' => date('F d', $due_timestamp),
                        'rent' => get_field('monthly_rent', $t_id),
                        'timestamp' => $due_timestamp
                    );
                }
            }
        }
        wp_reset_postdata();
    }

    if (!empty($upcoming_dues)) {
        usort($upcoming_dues, function($a, $b) {
            return $a['timestamp'] <=> $b['timestamp'];
        });
    }

    ob_start();
    echo '<div class="ef-due-container" style="font-family: inherit; width: 100%;">';

    if (empty($upcoming_dues)) {
        echo '<div class="ef-status-clear" style="border-left: 4px solid #4b6e31; background-color: #608D3F; padding: 16px; border-radius: 4px; color: #ffffff;">';
