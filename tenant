if (!function_exists('ef_handle_get_properties_dashboard')) {
function ef_handle_get_properties_dashboard() {
    check_ajax_referer('ef_property_nonce', 'nonce');
    if (!is_user_logged_in()) {
        wp_send_json_error('Unauthorized.');
    }

    $properties = get_posts([
        'post_type'   => 'property',
        'numberposts' => -1,
        'post_status' => 'publish',
        'orderby'     => 'date',
        'order'       => 'DESC'
    ]);

    if (empty($properties)) {
        wp_send_json_success([]);
    }

    $property_ids = wp_list_pluck($properties, 'ID');


    $all_tenants = get_posts([
        'post_type'   => 'ef_tenant',
        'post_status' => 'publish',
        'numberposts' => -1,
        'meta_query'  => [
            [
                'key'     => 'property_id',
                'value'   => $property_ids,
                'compare' => 'IN',
            ],
        ],
    ]);

    $tenants_by_property = [];
    $all_tenant_ids = [];
    foreach ($all_tenants as $t) {
        $p_id = get_post_meta($t->ID, 'property_id', true);
        $tenants_by_property[$p_id][] = $t;
        $all_tenant_ids[] = $t->ID;
    }


    $current_month = date('m');
    $current_year  = date('Y');

    $all_payments = [];
    if (!empty($all_tenant_ids)) {
        $all_payments = get_posts([
            'post_type'      => 'payment',
            'posts_per_page' => -1,
            'post_status'    => ['publish', 'future'],
            'date_query'     => [['year' => $current_year, 'month' => $current_month]],
            'meta_query'     => [['key' => 'associated_tenant', 'value' => $all_tenant_ids, 'compare' => 'IN']]
        ]);
    }

    $payments_by_tenant = [];
    foreach ($all_payments as $pay) {
        $t_id = get_post_meta($pay->ID, 'associated_tenant', true);
        $payments_by_tenant[$t_id][] = $pay;
    }

    $data = [];
    foreach ($properties as $p) {
        $p_tenants = isset($tenants_by_property[$p->ID]) ? $tenants_by_property[$p->ID] : [];
        $occupied = count($p_tenants);

        $units = 0;
        if (function_exists('get_field')) {
            $units = intval(get_field('number_unit', $p->ID));
        }
        if (!$units) {
            $units = intval(get_post_meta($p->ID, 'number_unit', true)) ?: intval(get_post_meta($p->ID, 'property_units', true)) ?: 0;
        }

        $expected = 0;
        $collected = 0;
        foreach ($p_tenants as $t) { if (function_exists("ef_is_tenant_billable") && !ef_is_tenant_billable($t->ID, date("m"), date("Y"))) continue;
            $monthly_rent = 0;
            if (function_exists('get_field')) {
                $monthly_rent = floatval(get_field('monthly_rent', $t->ID));
            }
            if (!$monthly_rent) {
                $monthly_rent = floatval(get_post_meta($t->ID, 'monthly_rent', true));
            }
            $expected += $monthly_rent;

            $t_payments = isset($payments_by_tenant[$t->ID]) ? $payments_by_tenant[$t->ID] : [];
            foreach ($t_payments as $pay) {
                $amount_paid = 0;
                if (function_exists('get_field')) {
                    $amount_paid = floatval(get_field('amount_paid', $pay->ID));
                }
                if (!$amount_paid) {
                    $amount_paid = floatval(get_post_meta($pay->ID, 'amount_paid', true));
                }
                $collected += $amount_paid;
            }
        }

        $data[] = [
            'id'        => $p->ID,
            'name'      => function_exists('get_field') ? (get_field('add_property', $p->ID) ?: $p->post_title) : $p->post_title,
            'type'      => function_exists('get_field') ? (get_field('property_type', $p->ID) ?: 'Property') : (get_post_meta($p->ID, 'property_type', true) ?: 'Property'),
            'units'     => $units,
            'occupied'  => $occupied,
            'address'   => function_exists('get_field') ? get_field('add_address', $p->ID) : get_post_meta($p->ID, 'add_address', true),
            'expected'  => $expected,
            'collected' => $collected
        ];
    }
    wp_send_json_success($data);
}
}

