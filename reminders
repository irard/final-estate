if (!function_exists('ef_render_reminder_card')) {    
    function ef_render_reminder_card($id_prefix, $title, $items_html, $count) {    
        $icon = ef_get_reminder_svg_icon($id_prefix);    
    
        if ($count === 0) {    
            $empty_msg = "Nothing here";    
            if ($id_prefix === 'overdue') $empty_msg = "🎉 All tenants are paid for this month!";    
            return "    
            <div class='ef-reminder-card'>    
                <div class='ef-reminder-header'>    
                    <div class='ef-reminder-title-group'><span class='ef-reminder-icon'>$icon</span>$title</div>    
                    <span class='ef-reminder-count'>0</span>    
                </div>    
                <div class='ef-reminder-empty'>$empty_msg</div>    
            </div>";    
        }    
    
        $output = "    
        <div class='ef-reminder-card' id='ef-{$id_prefix}-container'>    
            <div class='ef-reminder-header'>    
                <div class='ef-reminder-title-group'>    
                    <span class='ef-reminder-icon'>$icon</span>    
                    $title    
                </div>    
                <span class='ef-reminder-count'>{$count}</span>    
            </div>    
    
            <div class='ef-{$id_prefix}-list-wrapper'>    
                {$items_html}    
            </div>    
    
            <div class='ef-reminder-pagination' style='" . ($count <= 5 ? 'display:none;' : '') . "'>    
                <button id='ef-{$id_prefix}-prev' class='ef-reminder-pag-btn'>Previous</button>    
                <span id='ef-{$id_prefix}-page-info' class='ef-reminder-pag-info'>Page 1 of 1</span>    
                <button id='ef-{$id_prefix}-next' class='ef-reminder-pag-btn'>Next</button>    
            </div>    
        </div>    
    
        <script>    
        (function() {    
            const itemsPerPage = 4;    
            let currentPage = 1;    
            const container = document.getElementById('ef-{$id_prefix}-container');    
            if(!container) return;    
    
            const items = container.querySelectorAll('.ef-reminder-item');    
            const totalPages = Math.ceil(items.length / itemsPerPage);    
            if (totalPages <= 1) return;    
    
            const prevBtn = document.getElementById('ef-{$id_prefix}-prev');    
            const nextBtn = document.getElementById('ef-{$id_prefix}-next');    
            const pageInfo = document.getElementById('ef-{$id_prefix}-page-info');    
    
            function showPage(page) {    
                let start = (page - 1) * itemsPerPage;    
                let end = start + itemsPerPage;    
    
                items.forEach((item, index) => {    
                    item.style.display = (index >= start && index < end) ? 'flex' : 'none';    
                });    
    
                pageInfo.textContent = 'Page ' + page + ' of ' + totalPages;    
                prevBtn.disabled = (page === 1);    
                nextBtn.disabled = (page === totalPages);    
                prevBtn.style.opacity = (page === 1) ? '0.5' : '1';    
                nextBtn.style.opacity = (page === totalPages) ? '0.5' : '1';    
            }    
    
            prevBtn.addEventListener('click', function() {    
                if(currentPage > 1) { currentPage--; showPage(currentPage); }    
            });    
    
            nextBtn.addEventListener('click', function() {    
                if(currentPage < totalPages) { currentPage++; showPage(currentPage); }    
            });    
    
            showPage(currentPage);    
        })();    
        </script>";    
        return $output;    
    }    
}    
    
  
