                    <div class='ef-reminder-item-sub'>" . esc_html($method) . " · " . esc_html($period) . "</div>
                </div>
                <div style='text-align: right;'>
                    <div class='ef-reminder-item-amount paid'>AED " . number_format(floatval($amount)) . "</div>
                    <div class='ef-reminder-item-badge'>✓ " . esc_html($display_date) . "</div>
                </div>
            </div>";
        }    
        wp_reset_postdata();    
    }    
    return ef_render_reminder_card('paid', 'Recent Payments', $items_html, $count);
});    
    
add_shortcode('outstanding_tenants', function() {   
    if ( ! function_exists( 'get_field' ) ) { 
        return ''; 
    } 
 
    $current_month_year = date('Y-m');   
       
    $tenants = get_posts([   
        'post_type'      => 'ef_tenant',   
        'post_status'    => 'publish',   
        'posts_per_page' => -1,   
    ]);   
   
    $payments_by_tenant = [];   
    $outstanding_items = []; 
 
    if (!empty($tenants)) { 
        $current_period = date('Y-m');
        $p_query = new WP_Query([   
            'post_type'      => 'payment',   
            'post_status'    => ['publish', 'future'],
            'posts_per_page' => -1,   
        ]);   
   
        if ($p_query->have_posts()) {   
            while ($p_query->have_posts()) {   
                $p_query->the_post();   
                $pay_id = get_the_ID();   
                $period = get_field('payment_period', $pay_id) ?: get_post_meta($pay_id, 'payment_period', true) ?: get_the_date('Y-m', $pay_id);
                if (strpos($period, $current_period) === 0) {
                    $tid = get_field('associated_tenant', $pay_id) ?: get_post_meta($pay_id, 'associated_tenant', true);   
                    $amount = floatval(get_field('amount_paid', $pay_id) ?: get_post_meta($pay_id, 'amount_paid', true));   
                       
                    if ($tid) {   
                        if (!isset($payments_by_tenant[$tid])) {   
                            $payments_by_tenant[$tid] = 0;   
                        }   
                        $payments_by_tenant[$tid] += $amount;   
                    }
                }   
            }   
            wp_reset_postdata();   
        }   
   
        $m = date('m'); $y = date('Y');
        foreach ($tenants as $tenant) {   
            $tid = $tenant->ID;   
            if (ef_is_tenant_billable($tid, $m, $y)) {
                $rent = floatval(get_field('monthly_rent', $tid) ?: get_post_meta($tid, 'monthly_rent', true));   
                   
                if ($rent <= 0) continue;   
    
                $paid = isset($payments_by_tenant[$tid]) ? $payments_by_tenant[$tid] : 0; 
   
                if ($paid < $rent) {   
                    $due_day = get_field('rent_due_day', $tid) ?: get_post_meta($tid, 'rent_due_day', true);   
                    $outstanding_items[] = [   
                        'name'    => get_the_title($tid),   
                        'due_day' => $due_day ?: '01',   
                        'amount'  => $rent - $paid   
                    ];   
                }
            }   
        }   
   
        usort($outstanding_items, function($a, $b) {   
            return intval($a['due_day']) <=> intval($b['due_day']);   
        });   
    } 

    $items_html = '';
    $count = count($outstanding_items);

    foreach ($outstanding_items as $item) {
        $items_html .= "
        <div class='ef-reminder-item'>
            <div>
                <div class='ef-reminder-item-name'>" . esc_html($item['name']) . "</div>
                <div class='ef-reminder-item-sub'>Due day " . esc_html($item['due_day']) . "</div>
            </div>
            <div style='text-align: right;'>
                <div class='ef-reminder-item-amount overdue'>AED " . number_format($item['amount']) . "</div>
                <div class='ef-reminder-item-badge ef-badge-overdue'>Outstanding</div>
            </div>
        </div>";
    }

    return ef_render_reminder_card('outstanding', 'Outstanding', $items_html, $count);
}); 
add_shortcode('ef_upcoming_due_this_week', function() {
    $start_of_week = strtotime('monday this week 00:00:00');
    $end_of_week   = strtotime('sunday this week 23:59:59');

    $t_query = new WP_Query(array(
        'post_type'      => 'ef_tenant',
        'post_status'    => 'publish',
        'posts_per_page' => -1,
    ));

    $upcoming_dues = array();
    $current_year  = date('Y');
    $current_month = date('m');

    if ($t_query->have_posts()) {
        while ($t_query->have_posts()) {
            $t_query->the_post();
            $t_id = $t_query->post->ID;

            $due_day = get_field('rent_due_day', $t_id);

            if ($due_day) {
                $due_timestamp = strtotime("$current_year-$current_month-" . str_pad($due_day, 2, '0', STR_PAD_LEFT));

                if ($due_timestamp >= $start_of_week && $due_timestamp <= $end_of_week) {
                    $upcoming_dues[] = array(
                        'name' => get_the_title(),
                        'date' => date('F d', $due_timestamp),
                        'rent' => get_field('monthly_rent', $t_id),
                        'timestamp' => $due_timestamp
                    );
                }
            }
        }
        wp_reset_postdata();
    }

    if (!empty($upcoming_dues)) {
        usort($upcoming_dues, function($a, $b) {
            return $a['timestamp'] <=> $b['timestamp'];
        });
    }

    ob_start();
    echo '<div class="ef-due-container" style="font-family: inherit; width: 100%;">';

    if (empty($upcoming_dues)) {
        echo '<div class="ef-status-clear" style="border-left: 4px solid #4b6e31; background-color: #608D3F; padding: 16px; border-radius: 4px; color: #ffffff;">';
        echo '<strong style="display:block; margin-bottom: 4px;">📅 Schedule Clear</strong>';
        echo '<span style="font-size: 14px; color: #f1f5f1;">No standard tenant lease renewals or recurring balances are scheduled for this weekly cycle.</span>';
        echo '</div>';
    } else {
        echo '<p style="font-size: 14px; color: #6b7280; margin-bottom: 12px;">Accounts with upcoming invoice generation rules this week:</p>';
        echo '<ul style="list-style: none; padding: 0; margin: 0;">';
        foreach ($upcoming_dues as $due) {
            echo '<li style="display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px solid #e5e7eb; font-size: 15px;">';
            echo '<div>';
            echo '<span style="font-weight: 500; color: #1f2937; display: block;">' . esc_html($due['name']) . '</span>';
            echo '<span style="font-size: 12px; color: #6b7280;">Due on: ' . esc_html($due['date']) . '</span>';
            echo '</div>';
            echo '<span style="color: #4b5563; font-weight: 600;">AED ' . number_format(floatval($due['rent'])) . '</span>';
            echo '</li>';
        }
        echo '</ul>';
    }

    echo '</div>';
    return ob_get_clean();
});
