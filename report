add_action('wp_ajax_ef_export_report', 'ef_handle_report_export_download');
add_action('wp_ajax_nopriv_ef_export_report', 'ef_handle_report_export_download');

function ef_handle_report_export_download() {
    if (empty($_POST['report_year']) || empty($_POST['report_format'])) {
        wp_die('Missing parameters.');
    }

    $year = sanitize_text_field($_POST['report_year']);
    $format = sanitize_text_field($_POST['report_format']);

    $t_query = new WP_Query(array('post_type' => 'ef_tenant', 'post_status' => 'publish', 'posts_per_page' => -1));
    $tenants = [];
    if ($t_query->have_posts()) {
        while ($t_query->have_posts()) {
            $t_query->the_post();
            $t_id = get_the_ID();
            $tenants[] = [
                'id'   => $t_id,
                'rent' => floatval(get_field('monthly_rent', $t_id) ?: get_post_meta($t_id, 'monthly_rent', true))
            ];
        }
        wp_reset_postdata();
    }

    $months = array('Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec');
    $report_rows = array();
    $total_yearly_revenue = 0; $total_yearly_expected = 0; $total_yearly_gap = 0;
    $total_yearly_billable_count = 0; $total_yearly_paid_count = 0;

    foreach ($months as $index => $month_name) {
        $padded_month = str_pad($index + 1, 2, '0', STR_PAD_LEFT);
        $period_match = $year . '-' . $padded_month;

        $p_query = new WP_Query(array(
            'post_type'      => 'payment',
            'post_status'    => ['publish', 'future'],
            'posts_per_page' => -1,
        ));

        $collected_monthly = 0.00;
        $payments_by_tenant = [];
        if ($p_query->have_posts()) {
            while ($p_query->have_posts()) {
                $p_query->the_post();
                $p_id = get_the_ID();
                $period = get_field('payment_period', $p_id) ?: get_post_meta($p_id, 'payment_period', true) ?: get_the_date('Y-m', $p_id);
                if (strpos($period, $period_match) === 0) {
                    $pay_val = get_field('amount_paid', $p_id) ?: get_post_meta($p_id, 'amount_paid', true);
                    if ($pay_val) { $collected_monthly += floatval($pay_val); }
                    $tid = get_field('associated_tenant', $p_id) ?: get_post_meta($p_id, 'associated_tenant', true);
                    if ($tid) {
                        if (!isset($payments_by_tenant[$tid])) $payments_by_tenant[$tid] = 0;
                        $payments_by_tenant[$tid] += floatval($pay_val);
                    }
                }
            }
            wp_reset_postdata();
        }

        $expected_monthly = 0.00;
        $billable_tenants_count = 0;
        $paid_tenants_count = 0;
        foreach ($tenants as $tenant) {
            if (ef_is_tenant_billable($tenant['id'], $padded_month, $year)) {
                $expected_monthly += $tenant['rent'];
                if ($tenant['rent'] > 0) {
                    $billable_tenants_count++;
                    $paid_amount = isset($payments_by_tenant[$tenant['id']]) ? $payments_by_tenant[$tenant['id']] : 0;
                    if ($paid_amount >= $tenant['rent']) {
                        $paid_tenants_count++;
                    }
                }
            }
        }

        $gap_monthly = max(0, $expected_monthly - $collected_monthly);
        $rate_monthly = ($billable_tenants_count > 0) ? round(($paid_tenants_count / $billable_tenants_count) * 100) : 0;

        $total_yearly_revenue += $collected_monthly;
        $total_yearly_expected += $expected_monthly;
        $total_yearly_gap += $gap_monthly;
        $total_yearly_billable_count += $billable_tenants_count;
        $total_yearly_paid_count += $paid_tenants_count;

        $report_rows[] = array(
            'month'    => $month_name . ' ' . $year,
            'revenue'  => $collected_monthly,
            'expected' => $expected_monthly,
            'gap'      => $gap_monthly,
            'rate'     => $rate_monthly . '%'
        );
    }
    $total_yearly_rate = ($total_yearly_billable_count > 0) ? round(($total_yearly_paid_count / $total_yearly_billable_count) * 100) : 0;

    if ($format === 'csv') {
        header('Content-Type: text/csv; charset=utf-8');
        header('Content-Disposition: attachment; filename=estateflow-financial-report-' . $year . '.csv');
        $output = fopen('php://output', 'w');

        fputcsv($output, array('ESTATEFLOW ANNUAL SUMMARY (' . $year . ')'));
        fputcsv($output, array('Metric Name', 'Calculated Value'));
        fputcsv($output, array('Total Yearly Revenue Collected', '$' . number_format($total_yearly_revenue, 2)));
