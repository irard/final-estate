                    </button> 
                    <button class="ef-btn-row-action delete" title="Delete" onclick='efDeleteTransaction(${entry.id})'> 
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:inline-block; vertical-align:middle; margin-top:-2px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg> 
                    </button> 
                </td>     
            `;     
            outputBody.appendChild(rowHtml);     
        }     
    });     
   
    document.getElementById('efLedgerCounterDisplay').innerHTML = `${matchCount} results • <span>AED ${revenueAccumulator.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>`;     
    fallbackEl.style.display = (matchCount === 0) ? 'block' : 'none';     
}     
   
function efEscapeOutputChar(str) {     
    if (!str) return '';     
    return String(str)     
        .replace(/&/g, '&amp;')     
        .replace(/</g, '&lt;')     
        .replace(/>/g, '&gt;')     
        .replace(/"/g, '&quot;')     
        .replace(/'/g, '&#039;');     
}     
 
function efEditTransaction(id) { 
    const entry = efLedgerSourcePayload.find(item => item.id === id); 
    if (!entry) return; 
 
    document.getElementById('efModalTitle').innerText = 'Edit payment'; 
    document.getElementById('efSubmitBtn').innerText = 'Update payment'; 
    document.getElementById('ef_log_payment_id').value = entry.id; 
    document.getElementById('ef_log_tenant').value = entry.tenant_id; 
    document.getElementById('ef_log_tenant').dispatchEvent(new Event('change'));
    document.getElementById('ef_log_amount').value = entry.amount; 
    document.getElementById('ef_log_method').value = entry.method; 
    document.getElementById('ef_log_transaction_cheque_number').value = entry.transaction_cheque_number || '';
    document.getElementById('ef_log_period').value = entry.period; 
    document.getElementById('ef_log_date').value = entry.raw_date; 
 
    document.getElementById('efLogPaymentGlobalModal').style.display = 'flex'; 
} 
 
function efDeleteTransaction(id) { 
    if (confirm("are you sure you want delete this transaction it will be deleted forever")) { 
        var fd = new FormData(); 
        fd.append('action', 'ef_action_delete_payment_record'); 
        fd.append('nonce', document.getElementById('ef_table_nonce').value);
        fd.append('payment_id', id); 
 
        fetch('<?php echo admin_url('admin-ajax.php'); ?>', { method: 'POST', body: fd }) 
        .then(res => res.json()) 
        .then(res => { 
            if (res.success) { 
                window.location.reload(); 
            } else { 
                alert(res.data.message || 'Deletion failure.'); 
            } 
        }).catch(err => { alert('Database communication channel interrupted.'); }); 
    } 
} 
  
function efDownloadReceipt(d) {  
    if (!d) return;  

    const ref = d.receipt_voucher || d.ref || ('REC-' + String(d.id).padStart(6, '0'));  
    const amount = d.amount_formatted || (typeof d.amount === 'number' ? d.amount.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : d.amount);  
    const prop = d.property || d.prop || 'N/A';

    document.getElementById('pr-ref').innerText = ref;
    document.getElementById('pr-tenant').innerText = d.tenant || 'Unknown';
    document.getElementById('pr-prop').innerText = prop;
    document.getElementById('pr-cheque').innerText = d.transaction_cheque_number || '';
    document.getElementById('pr-date').innerText = d.date || '';
    document.getElementById('pr-period').innerText = d.period || '';
    document.getElementById('pr-method').innerText = d.method || '';
    document.getElementById('pr-amt-table').innerText = amount;
    document.getElementById('pr-amt-total').innerText = amount;
    document.getElementById('pr-desc').innerText = `Unit Reference: ${prop} (${d.period || ''})`;

    const source = document.querySelector('#payment-receipt-template .receipt-container');
    const clone = source.cloneNode(true);

    const wrapper = document.createElement('div');  
    wrapper.style.position = 'fixed';
    wrapper.style.left = '0';
    wrapper.style.top = '0';  
    wrapper.style.width = '800px';
    wrapper.style.zIndex = '-9999';
    wrapper.style.display = 'block';
    wrapper.appendChild(clone);
    document.body.appendChild(wrapper);  
    const options = {
        margin: 0,
        filename: `Receipt-${ref}.pdf`,
        image: { type: "jpeg", quality: 0.98 },
        html2canvas: {
            scale: 2,
            logging: false,
            useCORS: true,
            windowWidth: 800,
            width: 800,
            x: 0,
            y: 0,
            scrollY: 0,
            scrollX: 0
        },
        jsPDF: { unit: "in", format: "letter", orientation: "portrait" }
    };

    const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

    html2pdf().set(options).from(clone).outputPdf('blob').then(function(blob) {
        const url = URL.createObjectURL(blob);
        if (isMobile) {
            window.open(url, '_blank');
        } else {
            const a = document.createElement('a');
            a.href = url;
            a.download = `Receipt-${ref}.pdf`;
