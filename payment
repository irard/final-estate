function ef_internal_create_payment_record($tenant_id, $property_id, $tenant_name, $amount, $method, $ref, $date, $period, $voucher) {
    $period_ts = strtotime($period . '-01');
    $post_title  = $tenant_name . ' - ' . ($period_ts ? date('M Y', $period_ts) : date('M Y', strtotime($date)));   
    $new_id = wp_insert_post([   
        'post_title'  => $post_title,   
        'post_type'   => 'payment',    
        'post_status' => 'publish'
    ]);   
    if ($new_id && !is_wp_error($new_id)) {
        $meta = [
            'associated_tenant' => $tenant_id,
            'associated_property' => $property_id,
            'amount_paid'       => $amount,
            'date_of_payment'   => $date,
            'mode_of_payment'   => $method,
            'transaction_cheque_number' => $ref,
            'receipt_voucher'   => $voucher,
            'payment_period'    => $period
        ];
        foreach ($meta as $k => $v) {
            if (function_exists('update_field')) update_field($k, $v, $new_id);
            else update_post_meta($new_id, $k, $v);
        }
        return $new_id;
    }
    return false;
}

add_action('wp_ajax_ef_action_create_payment_record', 'ef_callback_ajax_create_payment');   
function ef_callback_ajax_create_payment() {   
    check_ajax_referer('ef_payment_nonce', 'nonce');
    if (!is_user_logged_in()) {
        wp_send_json_error(['message' => 'Unauthorized.']);
    }

    $tenant_id  = isset($_POST['tenant_id']) ? intval($_POST['tenant_id']) : 0;   
    $total_amount = isset($_POST['amount']) ? ef_clean_amount($_POST['amount']) : 0;   
    $method     = isset($_POST['method']) ? sanitize_text_field($_POST['method']) : 'Bank Transfer';   
    $transaction_cheque_number = isset($_POST['transaction_cheque_number']) ? sanitize_text_field($_POST['transaction_cheque_number']) : '';
    $date       = isset($_POST['date']) ? sanitize_text_field($_POST['date']) : '';   
    $period_ui  = isset($_POST['period']) ? sanitize_text_field($_POST['period']) : ''; // YYYY-MM
   
    if (!$tenant_id || $total_amount <= 0 || !$date || !$period_ui) {   
        wp_send_json_error(['message' => 'Operational parameters data validation failure.']);   
    }   

    $monthly_rent = ef_clean_amount((function_exists('get_field') ? get_field('monthly_rent', $tenant_id) : null) ?: get_post_meta($tenant_id, 'monthly_rent', true));
    $tenant_start = (function_exists('get_field') ? get_field('tenant_start', $tenant_id) : null) ?: get_post_meta($tenant_id, 'tenant_start', true);
    $tenant_end = (function_exists('get_field') ? get_field('tenant_end', $tenant_id) : null) ?: get_post_meta($tenant_id, 'tenant_end', true);
    $tenant_name = get_the_title($tenant_id);
    $property_id = (function_exists('get_field') ? get_field('property_id', $tenant_id) : null) ?: get_post_meta($tenant_id, 'property_id', true);

    // Calculate next receipt voucher number
    $last_payments = get_posts([
        'post_type'      => 'payment',
        'post_status'    => ['publish', 'future'],
        'posts_per_page' => 1,
        'meta_key'       => 'receipt_voucher',
        'orderby'        => 'meta_value_num',
        'order'          => 'DESC'
    ]);
    $next_voucher_int = 1;
    if (!empty($last_payments)) {
        $last_voucher = get_post_meta($last_payments[0]->ID, 'receipt_voucher', true);
        $next_voucher_int = intval($last_voucher) + 1;
    }

    if ($monthly_rent <= 0) {
        $receipt_voucher = str_pad($next_voucher_int, 3, '0', STR_PAD_LEFT);
        $new_id = ef_internal_create_payment_record($tenant_id, $property_id, $tenant_name, $total_amount, $method, $transaction_cheque_number, $date, $period_ui, $receipt_voucher);
        if ($new_id) wp_send_json_success(['payment_id' => $new_id]);
        else wp_send_json_error();
    }

    // Waterfall allocation logic
    $amount_remaining = $total_amount;
    $current_date_ts = $period_ui ? strtotime($period_ui . '-01') : ($tenant_start ? strtotime($tenant_start) : time());
    $current_date = date('Y-m-01', $current_date_ts);

    // Fetch existing payments once to calculate monthly balances
    $existing_payments = get_posts([
        'post_type' => 'payment',
        'post_status' => ['publish', 'future', 'pending', 'draft', 'private'],
        'numberposts' => -1,
        'meta_query' => [
            'relation' => 'OR',
            ['key' => 'associated_tenant', 'value' => $tenant_id, 'compare' => '=' ],
            ['key' => 'select_tenant', 'value' => $tenant_id, 'compare' => '=' ]
        ]
    ]);

    $monthly_paid = [];
    foreach ($existing_payments as $p) {
        $p_period = (function_exists('get_field') ? get_field('payment_period', $p->ID) : null) ?: get_post_meta($p->ID, 'payment_period', true) ?: get_the_date('Y-m', $p->ID);
        $p_period = substr((string)$p_period, 0, 7);
        $amt = ef_clean_amount((function_exists('get_field') ? get_field('amount_paid', $p->ID) : null) ?: get_post_meta($p->ID, 'amount_paid', true));
        if (!isset($monthly_paid[$p_period])) $monthly_paid[$p_period] = 0;
        $monthly_paid[$p_period] += $amt;
    }

    // BLOCKER: Simulation to ensure payment doesn't surpass contract end
    $sim_amount = $amount_remaining;
    $sim_date = $current_date;
    $sim_limit = 120;
    while ($sim_amount >= 0.01 && $sim_limit > 0) {
        $y = date('Y', strtotime($sim_date));
        $m = date('m', strtotime($sim_date));
        $period_key = "$y-$m";
        if ($tenant_end && $sim_date > date('Y-m-01', strtotime($tenant_end))) {
            wp_send_json_error(['message' => "Payment cannot be accepted as it surpasses the tenant's contract end date ($tenant_end)."]);
        }
        if (ef_is_tenant_billable($tenant_id, $m, $y)) {
            $paid = isset($monthly_paid[$period_key]) ? $monthly_paid[$period_key] : 0;
            $balance = max(0, $monthly_rent - $paid);
            if ($balance > 0) {
                $allocation = min($sim_amount, $balance);
                $sim_amount -= $allocation;
            }
        }
        $sim_date = date('Y-m-01', strtotime("+1 month", strtotime($sim_date)));
        $sim_limit--;
    }
    if ($sim_amount >= 0.01) {
        if ($tenant_end && $sim_date > date('Y-m-01', strtotime($tenant_end))) {
             wp_send_json_error(['message' => "Payment cannot be accepted as it surpasses the tenant's contract end date ($tenant_end)."]);
        }
    }

    $created_ids = [];
    $safety_limit = 120; // 10 years limit
    while ($amount_remaining >= 0.01 && $safety_limit > 0) {
        $y = date('Y', strtotime($current_date));
        $m = date('m', strtotime($current_date));
        $period_key = "$y-$m";

        if (ef_is_tenant_billable($tenant_id, $m, $y)) {
            $paid = isset($monthly_paid[$period_key]) ? $monthly_paid[$period_key] : 0;
            $balance = max(0, $monthly_rent - $paid);

            if ($balance > 0) {
                $allocation = min($amount_remaining, $balance);
                $receipt_voucher = str_pad($next_voucher_int++, 3, '0', STR_PAD_LEFT);
                $new_id = ef_internal_create_payment_record($tenant_id, $property_id, $tenant_name, $allocation, $method, $transaction_cheque_number, $date, $period_key, $receipt_voucher);
                if ($new_id) $created_ids[] = $new_id;
                $amount_remaining -= $allocation;
            }
        }
        $current_date = date('Y-m-01', strtotime("+1 month", strtotime($current_date)));
        $safety_limit--;
    }

    // If there is still a remainder (e.g. advance payment beyond paid-up months)
    if ($amount_remaining >= 0.01) {
        $receipt_voucher = str_pad($next_voucher_int++, 3, '0', STR_PAD_LEFT);
        $period_to_use = date('Y-m', strtotime($current_date));
        $new_id = ef_internal_create_payment_record($tenant_id, $property_id, $tenant_name, $amount_remaining, $method, $transaction_cheque_number, $date, $period_to_use, $receipt_voucher);
        if ($new_id) $created_ids[] = $new_id;
    }

    if (!empty($created_ids)) {
        wp_send_json_success(['payment_id' => end($created_ids)]);
    } else {
        // Fallback: If no allocation happened, create one record for UI period
        $receipt_voucher = str_pad($next_voucher_int++, 3, '0', STR_PAD_LEFT);
        $new_id = ef_internal_create_payment_record($tenant_id, $property_id, $tenant_name, $total_amount, $method, $transaction_cheque_number, $date, $period_ui, $receipt_voucher);
        if ($new_id) wp_send_json_success(['payment_id' => $new_id]);
        else wp_send_json_error();
    }
}   
 
add_action('wp_ajax_ef_action_update_payment_record', 'ef_callback_ajax_update_payment'); 
function ef_callback_ajax_update_payment() { 
    check_ajax_referer('ef_payment_nonce', 'nonce');
    if (!is_user_logged_in()) {
        wp_send_json_error(['message' => 'Unauthorized.']);
    }

    $payment_id = isset($_POST['payment_id']) ? intval($_POST['payment_id']) : 0; 
    $tenant_id  = isset($_POST['tenant_id']) ? intval($_POST['tenant_id']) : 0;   
    $amount     = isset($_POST['amount']) ? ef_clean_amount($_POST['amount']) : 0;   
    $method     = isset($_POST['method']) ? sanitize_text_field($_POST['method']) : 'Bank Transfer';   
    $transaction_cheque_number = isset($_POST['transaction_cheque_number']) ? sanitize_text_field($_POST['transaction_cheque_number']) : '';
    $date       = isset($_POST['date']) ? sanitize_text_field($_POST['date']) : '';   
    $period     = isset($_POST['period']) ? sanitize_text_field($_POST['period']) : ''; // YYYY-MM
   
    if (!$payment_id || !$tenant_id || !$amount || !$date || !$period) {   
        wp_send_json_error(['message' => 'Operational parameters data validation failure.']);   
    }   

   
    $tenant_name = get_the_title($tenant_id);   
    $post_title  = $tenant_name . ' - ' . date('M Y', strtotime($date));   
   
    $updated_payment_id = wp_update_post([ 
        'ID'          => $payment_id, 
        'post_title'  => $post_title, 
        'post_status' => 'publish' // Force publish to prevent scheduling
    ]); 
   
    if($updated_payment_id && !is_wp_error($updated_payment_id)) {   
        $property_id = get_field('property_id', $tenant_id) ?: get_post_meta($tenant_id, 'property_id', true);
        $meta = [
            'associated_tenant' => $tenant_id,
            'associated_property' => $property_id,
            'amount_paid'       => $amount,
            'date_of_payment'   => $date,
            'mode_of_payment'   => $method,
            'transaction_cheque_number' => $transaction_cheque_number,
            'payment_period'    => $period
        ];
        foreach ($meta as $k => $v) {
            if (function_exists('update_field')) update_field($k, $v, $payment_id);
            else update_post_meta($payment_id, $k, $v);
        }
   
        wp_send_json_success(['payment_id' => $payment_id]);   
    }   
   
    wp_send_json_error();   
} 
 
add_action('wp_ajax_ef_action_delete_payment_record', 'ef_callback_ajax_delete_payment'); 
function ef_callback_ajax_delete_payment() { 
    check_ajax_referer('ef_payment_nonce', 'nonce');
    if (!is_user_logged_in()) {
        wp_send_json_error(['message' => 'Unauthorized.']);
    }
    $payment_id = isset($_POST['payment_id']) ? intval($_POST['payment_id']) : 0; 
    if (!$payment_id) { 
        wp_send_json_error(['message' => 'Invalid payment ID.']); 
    } 

    if (get_post_type($payment_id) !== 'payment') {
        wp_send_json_error(['message' => 'Invalid post type.']);
    }

    if (wp_delete_post($payment_id, true)) { 
