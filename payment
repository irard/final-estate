function efProcessLedgerQueryMatrix() {     
    const queryStr = document.getElementById('efLedgerInputSearch').value.toLowerCase();     
    const selTenant = document.getElementById('efLedgerSelectTenant').value;     
    const selMethod = document.getElementById('efLedgerSelectMethod').value;     
    const selPeriod = document.getElementById('efLedgerSelectPeriod').value;     
   
    const outputBody = document.getElementById('efLedgerGridInjectionTarget');     
    const fallbackEl = document.getElementById('efLedgerDataEmptyState');     
   
    outputBody.innerHTML = '';     
    let matchCount = 0;     
    let revenueAccumulator = 0;     
   
    efLedgerSourcePayload.forEach(entry => {     
        const matchSearch = !queryStr ||      
                            entry.tenant.toLowerCase().includes(queryStr) ||      
                            entry.property.toLowerCase().includes(queryStr) ||      
                            entry.method.toLowerCase().includes(queryStr) ||
                            (entry.transaction_cheque_number && entry.transaction_cheque_number.toLowerCase().includes(queryStr));     
   
        const matchTenant = !selTenant || entry.tenant === selTenant;     
        const matchMethod = !selMethod || entry.method === selMethod;     
        const matchPeriod = !selPeriod || entry.period === selPeriod;     
   
        if (matchSearch && matchTenant && matchMethod && matchPeriod) {     
            matchCount++;     
            revenueAccumulator += entry.amount;     
   
            const rowHtml = document.createElement('tr');     
            if (entry.tenant === 'Out of contract') {
                rowHtml.style.backgroundColor = '#ff9393';
            } else if (entry.status === 'Partial') {
                rowHtml.style.backgroundColor = 'rgb(253 248 195)';
            }
            
            const statusClass = entry.status === 'Paid' ? 'status-paid' : 'status-partial';

            rowHtml.innerHTML = `     
                <td class="ef-cell-bold-tenant">${efEscapeOutputChar(entry.tenant)}</td>     
                <td style="color: #475569;">${efEscapeOutputChar(entry.property)}</td>     
                <td><span class="ef-badge-pill-period">${efEscapeOutputChar(entry.period)}</span></td>     
                <td style="color: #475569;">${efEscapeOutputChar(entry.method)}</td>     
                <td style="color: #475569;">${efEscapeOutputChar(entry.transaction_cheque_number)}</td>
                <td style="color: #475569;">${efEscapeOutputChar(entry.date)}</td>     
                <td class="ef-cell-accent-currency-green">AED ${Number(entry.amount).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>     
                <td><div class="ef-payment-status-badge ${statusClass}">${efEscapeOutputChar(entry.status)}</div></td>
                <td style="text-align: right;">     
                     <button class="ef-btn-receipt-pdf-download" title="Download PDF" onclick='efDownloadReceipt(efLedgerSourcePayload.find(item => item.id === ${entry.id}))'>     
                       <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block; vertical-align:middle; margin-top:-2px;">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
    </svg>     
                    </button>  
     
                    <button class="ef-btn-row-action" title="Edit" onclick='efEditTransaction(${entry.id})'> 
