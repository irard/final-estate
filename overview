        <div style="position: relative; height: 250px; width: 100%;"> 
            <canvas id="efDashboardRevenueChart"></canvas> 
        </div> 
    </div> 
 
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> 
    <script> 
    (function() { 
        function generateDashboardGraph() { 
            const canvasElement = document.getElementById('efDashboardRevenueChart'); 
            if (!canvasElement || typeof Chart === 'undefined') return; 
 
            const revenueData = <?php echo json_encode($revenue_dataset); ?>; 
            const labelsArray = <?php echo json_encode($month_labels); ?>; 
            const currentMonthIdx = <?php echo ($selected_year == date('Y')) ? $current_month_index : -1; ?>; 
 
            new Chart(canvasElement.getContext('2d'), { 
                type: 'bar', 
                data: { 
                    labels: labelsArray, 
                    datasets: [{ 
                        label: 'Collection Revenue', 
                        data: revenueData, 
                        backgroundColor: function(context) { 
                            return context.dataIndex === currentMonthIdx ? '#608D3F' : '#c2dbb1'; 
                        }, 
                        borderRadius: 6, 
                        borderWidth: 0 
                    }] 
                }, 
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false, 
                    plugins: { 
                        legend: { display: false }, 
                        tooltip: { 
                            callbacks: { 
                                label: function(context) { 
                                    return 'Revenue: AED ' + context.parsed.y.toLocaleString(); 
                                } 
                            } 
                        } 
                    }, 
                    scales: { 
                        y: { 
                            beginAtZero: true, 
                            grid: { color: 'rgba(96, 141, 63, 0.1)' }, 
                            ticks: {  
                                color: '#557045',  
