if (!function_exists('ef_get_tenant_due_day')) {
    function ef_get_tenant_due_day($t_id) {
        $d = get_field('rent_due_day', $t_id) ?: get_field('due_day', $t_id) ?: get_post_meta($t_id, 'rent_due_day', true) ?: get_post_meta($t_id, 'due_day', true);
        if (!$d) return 5;
        if (is_numeric($d)) {
            $v = intval($d);
            if ($v >= 1 && $v <= 31) return $v;
            if (strlen((string)$v) === 8) return intval(substr((string)$v, 6, 2));
        }
        $ts = strtotime((string)$d);
        return $ts ? intval(date('j', $ts)) : 5;
    }
}
if (!function_exists('ef_is_tenant_billable')) {
    function ef_is_tenant_billable($t_id, $m, $y) {
        $s_str = get_field('tenant_start', $t_id) ?: get_post_meta($t_id, 'tenant_start', true);
        $e_str = get_field('tenant_end', $t_id) ?: get_post_meta($t_id, 'tenant_end', true);
        if (!$s_str) return true;

        $dd = ef_get_tenant_due_day($t_id);
        $dim = (int)date('t', strtotime("$y-$m-01"));
        $due_date_str = "$y-$m-" . str_pad(min($dd, $dim), 2, '0', STR_PAD_LEFT);
        
        if ($s_str > $due_date_str) return false;
        if ($e_str && $e_str < "$y-$m-01") return false;

        $start_ts = strtotime($s_str);
        $due_ts = strtotime($due_date_str);
        $diff_days = round(($due_ts - $start_ts) / (60 * 60 * 24));
        
        if ($diff_days < 25) return false;
        if ($e_str && $e_str < $due_date_str) return false;

        return true;
    }
}

if (!function_exists('ef_get_dashboard_period')) {
    function ef_get_dashboard_period() {
        $m = isset($_GET['ef_month']) ? str_pad(intval($_GET['ef_month']), 2, '0', STR_PAD_LEFT) : date('m');
        $y = isset($_GET['ef_year']) ? intval($_GET['ef_year']) : date('Y');
        return ['m' => $m, 'y' => $y, 'period' => "$y-$m"];
    }
}

if (!function_exists('ef_get_payment_tenant_id')) {
    function ef_get_payment_tenant_id($p_id) {
        $t = get_field('associated_tenant', $p_id) ?: get_post_meta($p_id, 'associated_tenant', true);
        if (!$t) {
            $t = get_field('select_tenant', $p_id) ?: get_post_meta($p_id, 'select_tenant', true);
        }
        if (!$t) return 0;
        if (is_array($t)) {
            $item = $t[0];
            return is_object($item) ? $item->ID : (is_array($item) ? ($item['ID'] ?? 0) : intval($item));
        }
        if (is_object($t)) return $t->ID;
        return intval($t);
    }
}

if (!function_exists('ef_get_payment_period')) {
    function ef_get_payment_period($p_id) {
        $p = get_field('payment_period', $p_id) ?: get_post_meta($p_id, 'payment_period', true);
        if ($p) return substr($p, 0, 7);
        $d = get_field('date_of_payment', $p_id) ?: get_post_meta($p_id, 'date_of_payment', true);
        if ($d) return date('Y-m', strtotime($d));
        return get_the_date('Y-m', $p_id);
    }
}

if (!function_exists('ef_get_tenant_monthly_status')) {
    function ef_get_tenant_monthly_status($t_id, $m, $y) {
        $rent_val = get_field('monthly_rent', $t_id) ?: get_post_meta($t_id, 'monthly_rent', true);
        $rent = floatval(str_replace(',', '', $rent_val));
        $period_match = "$y-$m";
        
        $payments = get_posts([
            'post_type' => 'payment',
            'post_status' => ['publish', 'future', 'pending', 'draft', 'private'],
            'posts_per_page' => -1,
            'meta_query' => [
                'relation' => 'OR',
                ['key' => 'associated_tenant', 'value' => $t_id, 'compare' => '='],
                ['key' => 'select_tenant', 'value' => $t_id, 'compare' => '='],
                ['key' => 'select_tenant', 'value' => '"' . $t_id . '"', 'compare' => 'LIKE'],
            ]
        ]);

        $paid = 0;
        foreach ($payments as $p) {
            $p_id = $p->ID;
            $p_period = ef_get_payment_period($p_id);
            if (strpos($p_period, $period_match) === 0) {
                $paid += floatval(get_field('amount_paid', $p_id) ?: get_post_meta($p_id, 'amount_paid', true));
            }
        }

        return [
            'paid' => $paid,
            'rent' => $rent,
            'is_fully_paid' => ($rent > 0 && $paid >= $rent) || ($rent == 0 && $paid > 0)
        ];
    }
}

