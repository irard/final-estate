add_shortcode('ef_outstanding_tenants_widget', function() { 
    $period_data = ef_get_dashboard_period();
    $m = $period_data['m']; $y = $period_data['y'];
    $current_period = $period_data['period'];
     
    $tenants = get_posts([ 
        'post_type'      => 'ef_tenant', 
        'post_status'    => 'publish', 
        'posts_per_page' => -1, 
    ]); 
 
    if (empty($tenants)) { 
        return '<div class="ef-dash-widget-box"><div class="ef-dash-empty">No tenants found.</div></div>'; 
    } 
    $p_query = new WP_Query([ 
        'post_type'      => 'payment', 
        'post_status'    => ['publish', 'future', 'pending', 'draft', 'private'],
        'posts_per_page' => -1, 
    ]); 
 
    $payments_by_tenant = []; 
    if ($p_query->have_posts()) { 
        while ($p_query->have_posts()) { 
            $p_query->the_post(); 
            $pay_id = get_the_ID(); 
            $period = ef_get_payment_period($pay_id);
            if (strpos($period, $current_period) === 0) {
                $tid = ef_get_payment_tenant_id($pay_id);
                $amount = floatval(get_field('amount_paid', $pay_id) ?: get_post_meta($pay_id, 'amount_paid', true)); 
                 
                if ($tid) { 
                    if (!isset($payments_by_tenant[$tid])) { 
                        $payments_by_tenant[$tid] = 0; 
                    } 
                    $payments_by_tenant[$tid] += $amount; 
                } 
            }
        } 
        wp_reset_postdata(); 
    } 
 
    $outstanding_items = []; 
    foreach ($tenants as $tenant) { 
        $tid = $tenant->ID; 
        if (ef_is_tenant_billable($tid, $m, $y)) {
            $rent_val = get_field('monthly_rent', $tid) ?: get_post_meta($tid, 'monthly_rent', true);
            $rent = floatval(str_replace(',', '', $rent_val)); 
             
            if ($rent <= 0) continue; 
    
            $paid = isset($payments_by_tenant[$tid]) ? $payments_by_tenant[$tid] : 0; 
    
            if ($paid < $rent) { 
                $due_day = get_field('rent_due_day', $tid) ?: get_post_meta($tid, 'rent_due_day', true); 
                $outstanding_items[] = [ 
                    'name'    => get_the_title($tid), 
                    'due_day' => $due_day ?: '01', 
                    'amount'  => $rent - $paid 
                ]; 
            } 
        }
    } 
 
    usort($outstanding_items, function($a, $b) { 
        return intval($a['due_day']) <=> intval($b['due_day']); 
    }); 
 
    $outstanding_items = array_slice($outstanding_items, 0, 5); 
 
    ob_start(); 
    ?> 
    <div class="ef-dash-widget-box"> 
        <div class="ef-dash-widget-header"> 
            <div> 
                <h3 class="ef-dash-widget-title">Outstanding</h3> 
                <p class="ef-dash-widget-subtitle">Tenants due this month</p> 
            </div> 
        </div> 
 
        <div class="ef-outstanding-stack"> 
            <?php if (!empty($outstanding_items)) : foreach ($outstanding_items as $item) : ?> 
                <div class="ef-outstanding-row"> 
                    <div> 
                        <span class="ef-out-tenant-name"><?php echo esc_html($item['name']); ?></span> 
                        <span class="ef-out-tenant-meta">Due day <?php echo esc_html($item['due_day']); ?></span> 
                    </div> 
                    <div class="ef-out-amount-text"> 
                        AED <?php echo number_format($item['amount']); ?> 
                    </div> 
                </div> 
            <?php endforeach; else : ?> 
                <div class="ef-dash-empty">No outstanding balances found.</div> 
            <?php endif; ?> 
        </div> 
    </div> 
    <?php 
    return ob_get_clean(); 
}); 
 
 
