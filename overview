            while ($p_query->have_posts()) { 
                $p_query->the_post(); 
                $p_id = get_the_ID();
                $period = ef_get_payment_period($p_id);
                if (strpos($period, $period_match) === 0) {
                    $pay_val = get_field('amount_paid', $p_id) ?: get_post_meta($p_id, 'amount_paid', true); 
                    if ($pay_val) { $revenue_collected += floatval($pay_val); } 
                }
            } 
            wp_reset_postdata(); 
        } 
        $revenue_dataset[] = $revenue_collected; 
    } 
 
    $current_month_index = intval(date('n', $current_time)) - 1; // 0-11 
 
    ob_start(); 
    ?> 
